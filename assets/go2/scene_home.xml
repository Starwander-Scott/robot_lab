<mujoco model="go2 home environment">
  <include file="go2.xml"/>

  <statistic center="10 7 0.5" extent="12"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.8 0.85 0.9" rgb2="0.5 0.6 0.7" width="512" height="3072"/>

    <!-- floor textures -->
    <texture type="2d" name="tile_tex" builtin="checker" mark="edge"
      rgb1="0.85 0.82 0.78" rgb2="0.75 0.72 0.68" markrgb="0.9 0.88 0.85" width="300" height="300"/>
    <material name="tile" texture="tile_tex" texuniform="true" texrepeat="12 12" reflectance="0.3"/>

    <texture type="2d" name="wood_floor_tex" builtin="checker"
      rgb1="0.65 0.45 0.25" rgb2="0.55 0.38 0.20" width="200" height="200"/>
    <material name="wood_floor" texture="wood_floor_tex" texuniform="true" texrepeat="15 15" reflectance="0.15"/>

    <texture type="2d" name="carpet_tex" builtin="flat"
      rgb1="0.4 0.25 0.25" rgb2="0.35 0.2 0.2" width="128" height="128"/>
    <material name="carpet" texture="carpet_tex" texuniform="true" reflectance="0.05"/>

    <texture type="2d" name="carpet_blue_tex" builtin="flat"
      rgb1="0.2 0.25 0.4" rgb2="0.18 0.22 0.35" width="128" height="128"/>
    <material name="carpet_blue" texture="carpet_blue_tex" texuniform="true" reflectance="0.05"/>

    <texture type="2d" name="marble_tex" builtin="checker" mark="cross"
      rgb1="0.9 0.88 0.85" rgb2="0.82 0.80 0.77" markrgb="0.85 0.83 0.8" width="300" height="300"/>
    <material name="marble" texture="marble_tex" texuniform="true" texrepeat="6 6" reflectance="0.5"/>

    <!-- furniture & wall materials -->
    <texture type="cube" name="wall_tex" builtin="flat" rgb1="0.92 0.90 0.85" rgb2="0.92 0.90 0.85" width="128" height="128"/>
    <material name="wall" texture="wall_tex"/>
    <texture type="cube" name="wood_tex" builtin="flat" rgb1="0.55 0.35 0.18" rgb2="0.5 0.3 0.15" width="128" height="128"/>
    <material name="wood" texture="wood_tex"/>
    <texture type="cube" name="dark_wood_tex" builtin="flat" rgb1="0.35 0.2 0.1" rgb2="0.3 0.18 0.08" width="128" height="128"/>
    <material name="dark_wood" texture="dark_wood_tex"/>
    <texture type="cube" name="sofa_tex" builtin="flat" rgb1="0.35 0.45 0.55" rgb2="0.3 0.4 0.5" width="128" height="128"/>
    <material name="sofa" texture="sofa_tex"/>
    <texture type="cube" name="sofa_brown_tex" builtin="flat" rgb1="0.5 0.3 0.15" rgb2="0.45 0.27 0.12" width="128" height="128"/>
    <material name="sofa_brown" texture="sofa_brown_tex"/>
    <texture type="cube" name="chrome_tex" builtin="flat" rgb1="0.7 0.7 0.72" rgb2="0.65 0.65 0.67" width="128" height="128"/>
    <material name="chrome" texture="chrome_tex" reflectance="0.4"/>
    <texture type="cube" name="cabinet_tex" builtin="flat" rgb1="0.9 0.88 0.85" rgb2="0.85 0.83 0.8" width="128" height="128"/>
    <material name="cabinet" texture="cabinet_tex"/>
    <texture type="cube" name="counter_tex" builtin="flat" rgb1="0.3 0.3 0.3" rgb2="0.25 0.25 0.25" width="128" height="128"/>
