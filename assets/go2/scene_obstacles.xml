<mujoco model="go2 obstacle course">
  <include file="go2.xml"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    
    <!-- 障碍物专用木材质 -->
    <texture type="cube" name="obstacle_tex" builtin="flat" rgb1="0.7 0.5 0.3" rgb2="0.7 0.5 0.3" width="127" height="127"/>
    <material name="obstacle_mat" texture="obstacle_tex"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <!-- 扩大地面的大小 -->
    <geom name="floor" size="10 10 0.05" type="plane" material="groundplane"/>

    <!-- ==================== 前方 (+X向): 楼梯测试测试区 ==================== -->
    <!-- 上楼梯 -->
    <geom pos="1.0 0 0.025" type="box" size="0.15 1.0 0.025" material="obstacle_mat"/>
    <geom pos="1.3 0 0.05"  type="box" size="0.15 1.0 0.05" material="obstacle_mat"/>
    <geom pos="1.6 0 0.075" type="box" size="0.15 1.0 0.075" material="obstacle_mat"/>
    <geom pos="1.9 0 0.1"   type="box" size="0.15 1.0 0.1" material="obstacle_mat"/>
    <!-- 平台 -->
    <geom pos="2.6 0 0.125" type="box" size="0.55 1.0 0.125" material="obstacle_mat"/>
    <!-- 下楼梯 -->
    <geom pos="3.3 0 0.1"   type="box" size="0.15 1.0 0.1" material="obstacle_mat"/>
    <geom pos="3.6 0 0.075" type="box" size="0.15 1.0 0.075" material="obstacle_mat"/>
    <geom pos="3.9 0 0.05"  type="box" size="0.15 1.0 0.05" material="obstacle_mat"/>
    <geom pos="4.2 0 0.025" type="box" size="0.15 1.0 0.025" material="obstacle_mat"/>

    <!-- ==================== 左方 (+Y向): 斜坡 (Ramps) 测试区 ==================== -->
    <!-- euler 旋转让方块倾斜成为斜坡 -->
    <geom pos="0 1.5 0.1" type="box" size="0.5 0.5 0.05" material="obstacle_mat" euler="15 0 0"/>
    <geom pos="0 2.2 0.23" type="box" size="0.5 0.5 0.05" material="obstacle_mat"/>
    <geom pos="0 2.9 0.1" type="box" size="0.5 0.5 0.05" material="obstacle_mat" euler="-15 0 0"/>

    <!-- ==================== 右方 (-Y向): 乱石阵 (Rough Terrain) ==================== -->
    <!-- 使用一堆随机摆放的小障碍物模拟不平整的非结构化地形 -->
    <geom pos="0 -1.5 0.02" type="box" size="0.2 0.2 0.02" material="obstacle_mat" euler="0 0 15"/>
    <geom pos="0.3 -1.8 0.03" type="box" size="0.15 0.2 0.03" material="obstacle_mat" euler="10 0 0"/>
    <geom pos="-0.2 -2.1 0.015" type="box" size="0.25 0.15 0.015" material="obstacle_mat" euler="0 15 0"/>
    <geom pos="0.4 -2.4 0.025" type="box" size="0.2 0.2 0.025" material="obstacle_mat" euler="5 5 5"/>
    <geom pos="0 -2.7 0.04" type="box" size="0.15 0.15 0.04" material="obstacle_mat" euler="-10 10 0"/>
    <geom pos="-0.3 -2.2 0.02" type="box" size="0.2 0.2 0.02" material="obstacle_mat"/>
    <geom pos="-0.4 -1.6 0.03" type="box" size="0.15 0.3 0.03" material="obstacle_mat" euler="0 -10 -10"/>
    <geom pos="0.4 -1.3 0.035" type="box" size="0.3 0.2 0.035" material="obstacle_mat" euler="15 0 20"/>

    <!-- ==================== 后方 (-X向): 梅花桩 (Stepping Stones) ==================== -->
    <!-- 地面悬空的圆柱体，考验落脚点精度 -->
    <geom pos="-1.2 0 0.05" type="cylinder" size="0.15 0.05" material="obstacle_mat"/>
    <geom pos="-1.7 0.1 0.06" type="cylinder" size="0.15 0.06" material="obstacle_mat"/>
    <geom pos="-2.2 -0.1 0.07" type="cylinder" size="0.15 0.07" material="obstacle_mat"/>
    <geom pos="-2.7 0.05 0.08" type="cylinder" size="0.15 0.08" material="obstacle_mat"/>
    <geom pos="-3.2 -0.05 0.09" type="cylinder" size="0.15 0.09" material="obstacle_mat"/>

  </worldbody>
</mujoco>